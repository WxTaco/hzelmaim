  # hzel - environment variable reference
  #
  # Copy this file to .env and fill in the values for your deployment.
  # Variables with defaults shown as :-value use that default when unset.
  
  # Database name (used by both the postgres image and DATABASE_URL construction)
  POSTGRES_DB=
  
  # PostgreSQL username
  POSTGRES_USER=
  
  # Postgres password, please change this in production or I will see to it personall that you don't make it out of this room alive.
  POSTGRES_PASSWORD=
  
  # Port the Rust API listens on inside the container (Dockerfile default: 8081)
  PORT=8081
  
  # Publicly reachable base URL of the frontend
  # Used to build absolute callback URLs (e.g. OIDC redirect URI).
  # Must include scheme and port if non-standard.
  PUBLIC_BASE_URL=https://hzel.heliki.preview.hzel.org
  
  # Rust log filter. Increase to "debug" or "trace" for verbose output.
  RUST_LOG=info,hzel_backend=debug
  
  # Full PostgreSQL connection string.
  # In docker-compose the host is the service name "db".
  # In local dev (cargo run) use localhost.
  DATABASE_URL=
  
  # Full URL to the Proxmox API endpoint.
  PROXMOX_API_URL=https://crosswind.waforix.org/api2/json

  # Proxmox API token in "user@realm!tokenname" format.
  PROXMOX_API_TOKEN_ID=
  
  # Secret value of the Proxmox API token.
  # Leave blank to use the built-in stub client (no real Proxmox calls).
  PROXMOX_API_TOKEN_SECRET=
  
  # Proxmox node name where containers are created (shown in the PVE UI).
  PROXMOX_NODE=
  
  # Container ID (CTID) of the LXC template to clone when provisioning new containers.
  PROXMOX_TEMPLATE_CTID=
  
  # Proxmox storage pool used for container rootfs (e.g. local-lvm, ceph-pool).
  PROXMOX_STORAGE=
  
  # Linux bridge to attach container network interfaces to.
  PROXMOX_BRIDGE=

  # Only required when your Proxmox API is behind a Cloudflare Access tunnel.
  # Leave blank if Proxmox is directly reachable.
  CF_ACCESS_CLIENT_ID=
  CF_ACCESS_CLIENT_SECRET=
  
  # Path to the ed25519 CA private key used to sign ephemeral SSH certificates.
  # The file must be an unencrypted OpenSSH private key.
  # Generate with: ssh-keygen -t ed25519 -f keys/ca -N ""
  # In docker-compose the keys/ directory is bind-mounted at /app/keys.
  # If this path does not exist, terminal sessions are simply unavailable.
  SSH_CA_PRIVATE_KEY_PATH=/app/keys/ca

  # Default Unix username for SSH sessions into containers.
  SSH_USER=root
  
  # Default SSH port on managed containers.
  SSH_PORT=22
  
  # Set to "true" to enable OIDC login. When false all OIDC fields are ignored.
  OIDC_ENABLED=true
  
  # Issuer URL of your OIDC provider (must expose a /.well-known/openid-configuration).
  # Examples: https://accounts.google.com
  #           https://your-tenant.auth0.com/
  #           https://sso.example.com/realms/myrealm
  OIDC_ISSUER_URL=https://i.hzel.org
  
  # Client ID registered with your OIDC provider.
  OIDC_CLIENT_ID=hzel
  
  # Client secret from your OIDC provider.
  OIDC_CLIENT_SECRET=
  
  # Redirect URI registered with your OIDC provider.
  # This is not an optional field
  OIDC_REDIRECT_URI=https://hzel-api.heliki.preview.hzel.org/api/v1/auth/oidc/callback
  
  # Secret used to sign JWTs issued by the backend.
  # Use a long random string in production: openssl rand -hex 32
  JWT_SECRET=
  
  # Set to "true" to automatically create a development session on startup.
  # Useful for local development without OIDC configured.
  # NEVER enable in production.
  BOOTSTRAP_DEV_SESSION=false

  # URL the *browser* uses to reach the backend API.
  # This is baked into the JS bundle at build time (NEXT_PUBLIC_ prefix).
  # For local docker-compose: http://localhost:8081
  # For production: https://api.yourdomain.com
  NEXT_PUBLIC_API_URL=https://hzel-api.heliki.preview.hzel.org